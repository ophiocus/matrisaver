<?xml version='1.0' encoding='windows-1252'?>

<!--
  MatriSaver MSI installer.

  Adapted from the I:\Skeleton\wix\main.wxs pattern but tailored for a
  Windows screensaver (.scr), which has fundamentally different install
  semantics than a regular .exe app:

    * The file goes into [SystemFolder] (= %SystemRoot%\System32\) so
      Windows scans it into the Display Properties → Screen Saver
      Settings dropdown automatically. There is no PATH entry to add and
      no Start Menu / Desktop shortcut to create — Windows itself is the
      launcher.

    * The build output is named matrisaver-host-windows.exe; the
      installed copy is renamed to matrisaver.scr at install time.
      Windows treats .scr the same as .exe for execution; only the
      extension matters for the screensaver scan.

    * InstallScope is perMachine: System32 is admin-only. There is no
      per-user MatriSaver install today.

  Known limitations of this scaffold (deferred to follow-up):

    * Overlay assets are NOT installed. resolve_overlay_directory()
      walks ancestors of the .exe path looking for assets/overlays/, and
      System32 has no such ancestor. After install, the user must either
      set MATRISAVER_OVERLAY_DIR or the overlay subsystem stays inert
      (rain still works). Adding [CommonAppDataFolder] install + an
      io.rs fallback is the next step.

    * No code signing. The first MSI will trip SmartScreen — that's a
      cert procurement question, not a WXS one.

    * No assets/icon.ico in the repo yet, so we do not declare an
      <Icon> element. ARP entry will use the Windows default. Add an
      <Icon Id='ProductICO' SourceFile='assets\icon.ico'/> + the two
      ARPPRODUCTICON / Shortcut Icon attributes once the asset lands.
-->

<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
    <!--
      WiX naming gotcha: `SystemFolder` is the 32-bit alias even on
      64-bit Windows (maps to SysWOW64). For an x64 install that needs
      to land in the real C:\Windows\System32, use `System64Folder`.
      ICE80 fires if a 64-bit Component lives in `SystemFolder`.
    -->
    <?define PlatformSystemFolder = "System64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
    <?define PlatformSystemFolder = "SystemFolder" ?>
<?endif ?>

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='MatriSaver'
        UpgradeCode='D5DED742-76E6-45CA-AF48-7D9B55A3B920'
        Manufacturer='ophiocus'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Description='Matrix-style digital rain Windows screensaver'
            Manufacturer='ophiocus'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'
            />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            AllowSameVersionUpgrades='yes'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
        <Property Id='DiskPrompt' Value='MatriSaver Installation'/>

        <!--
          Install matrisaver.scr directly into System32. The Source path
          points at the cargo-built matrisaver-host-windows.exe; Name is
          the destination filename. Windows treats .scr identically to
          .exe for execution; the extension is what matters for
          screensaver scanning.

          KeyPath component identity must remain stable across upgrades,
          so the GUID below is permanent — do not regenerate it.
        -->
        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='$(var.PlatformSystemFolder)'>
                <Component Id='ScreensaverBinary' Guid='352E329D-11F3-41AE-B9FE-789CAE253B78'>
                    <File
                        Id='MatrisaverScr'
                        Name='matrisaver.scr'
                        DiskId='1'
                        Source='$(var.CargoTargetBinDir)\matrisaver-host-windows.exe'
                        KeyPath='yes'/>
                </Component>
            </Directory>

            <!--
              Start Menu shortcut. The Target is rundll32.exe (always
              on PATH) invoking shell32.dll,Control_RunDLL with the
              desk.cpl `@screensaver` page argument — that is the
              Windows-blessed entry point to the Screen Saver settings
              page. MatriSaver is auto-listed in the dropdown there
              because System32\matrisaver.scr is picked up by the
              Display Properties scan; clicking the page's
              "Settings…" button then invokes our /c handler properly
              (Display Properties passes /c:<HWND> the way the WinAPI
              expects).

              The shortcut is in its own Feature so the customize
              page can show an opt-in checkbox. Default is on
              (Level='1', Absent='allow'). An uncheck makes the user
              fully responsible for remembering how to open the
              Screen Saver settings page on their own.
            -->
            <Directory Id='ProgramMenuFolder'>
                <Directory Id='AppShortcutFolder' Name='MatriSaver'>
                    <Component Id='StartMenuShortcut' Guid='D321BBC6-E019-41D9-8545-25554D1C83D1'>
                        <Shortcut Id='MatrisaverSettingsShortcut'
                                  Name='MatriSaver Settings'
                                  Description='Open the Windows Screen Saver settings page'
                                  Target='[$(var.PlatformSystemFolder)]rundll32.exe'
                                  Arguments='shell32.dll,Control_RunDLL desk.cpl,,@screensaver'
                                  WorkingDirectory='$(var.PlatformSystemFolder)'/>
                        <RemoveFolder Id='RemoveAppShortcutFolder'
                                      Directory='AppShortcutFolder'
                                      On='uninstall'/>
                        <!--
                          A non-file Component needs a KeyPath; per-user
                          registry value is the canonical pattern for
                          shortcut-only components.
                        -->
                        <RegistryValue Root='HKCU'
                                       Key='Software\ophiocus\MatriSaver'
                                       Name='StartMenuShortcut'
                                       Type='integer'
                                       Value='1'
                                       KeyPath='yes'/>
                    </Component>
                </Directory>
            </Directory>
        </Directory>

        <Feature
            Id='Screensaver'
            Title='Screensaver'
            Description='Installs matrisaver.scr into the Windows System folder so it appears in Display Properties → Screen Saver Settings.'
            Level='1'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>
            <ComponentRef Id='ScreensaverBinary'/>
        </Feature>

        <Feature
            Id='StartMenuShortcutFeature'
            Title='Start Menu shortcut'
            Description='Adds a "MatriSaver Settings" shortcut under Start → MatriSaver that opens the Screen Saver settings page directly.'
            Level='1'
            AllowAdvertise='no'
            Display='expand'
            Absent='allow'>
            <ComponentRef Id='StartMenuShortcut'/>
        </Feature>

        <Property Id='ARPHELPLINK' Value='https://github.com/ophiocus/matrisaver'/>
        <Property Id='ARPURLINFOABOUT' Value='https://github.com/ophiocus/matrisaver'/>

        <!--
          ExitDialog "launch now" affordance — same flavor as a
          "launch app now" / "open readme" checkbox most installers
          show on the final page. WIXUI_EXITDIALOGOPTIONALCHECKBOX
          controls the default check state (1 = checked); the text
          property is the checkbox label. The DoAction Publish below
          fires LaunchScreensaverSettings if the box is checked AND
          we just finished a fresh install (not uninstall).
        -->
        <Property Id='WIXUI_EXITDIALOGOPTIONALCHECKBOX' Value='1'/>
        <Property Id='WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT'
                  Value='Open Screen Saver Settings now'/>

        <CustomAction Id='LaunchScreensaverSettings'
                      ExeCommand='rundll32.exe shell32.dll,Control_RunDLL desk.cpl,,@screensaver'
                      Directory='$(var.PlatformSystemFolder)'
                      Return='asyncNoWait'
                      Impersonate='yes'/>

        <UI>
            <UIRef Id='WixUI_FeatureTree'/>

            <!--
              Skip the LicenseAgreementDlg path that WixUI_FeatureTree
              defaults into (avoids the WixUILicenseRtf / License.rtf
              lookup that bit us in v0.1.0). Welcome → Customize
              directly, and Back from Customize returns to Welcome.
              Mirrors the working pattern in I:\Skeleton\wix\main.wxs.
            -->
            <Publish Dialog='WelcomeDlg' Control='Next' Event='NewDialog' Value='CustomizeDlg' Order='99'>1</Publish>
            <Publish Dialog='CustomizeDlg' Control='Back' Event='NewDialog' Value='WelcomeDlg' Order='99'>1</Publish>

            <!-- Fire the launch-now custom action on Finish, only on fresh installs. -->
            <Publish Dialog='ExitDialog' Control='Finish' Event='DoAction' Value='LaunchScreensaverSettings'>WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed</Publish>
        </UI>

    </Product>

</Wix>
